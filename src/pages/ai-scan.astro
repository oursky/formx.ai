---
import PageLayout from '@/layouts/PageLayout.astro';
---

<PageLayout
  title="AI Scan – Effortless Document Scanning Powered by FormX.AI"
  description="A smart document scanning app that makes data extraction from receipts, invoices, and ID cards fast and easy."
  canonicalUrl="https://www.formx.ai/ai-scan/"
  ogImage="/images/pages/ai-scan/ai-scan-app-logo.webp"
  showFooterForm={false}
>

  {/* Hero */}
  <div class="section product-hero bg-f0f4f9">
    <div class="container-default w-container">
      <div class="product-hero-wrapper">
        <div class="hero-content-block">
          <div class="product-hero-content-wrapper">
            <h1 class="product-hero-content-heading">AI Scan</h1>
            <div class="product-hero-content-subheading">
              Effortless Document Scanning Powered by FormX.ai<br />
              A smart document scanning app that makes data extraction from receipts, invoices, and ID cards fast and easy.
            </div>
          </div>
          <div class="downlaod-on-app-store-flex">
            <a href="http://bit.ly/3ZbBIHW" target="_blank" rel="noopener" class="w-inline-block">
              <img
                src="/images/pages/ai-scan/google-play-badge.png"
                loading="lazy"
                alt="Get it on Google Play"
                class="download-on-app-store-badge"
              />
            </a>
            <a href="https://apps.apple.com/us/app/ai-scan-formx/id6444301909" target="_blank" rel="noopener" class="w-inline-block">
              <img
                src="/images/pages/ai-scan/app-store-badge.svg"
                loading="lazy"
                alt="Download on the App Store"
                class="download-on-app-store-badge"
              />
            </a>
            <a href="https://ai-scan.formxai.com/" target="_blank" rel="noopener" class="w-inline-block">
              <img
                src="/images/pages/ai-scan/web-app-badge.png"
                loading="lazy"
                alt="Open the web app"
                class="download-on-app-store-badge"
              />
            </a>
          </div>
        </div>
        <div class="hero-image-block">
          <img
            src="/images/pages/ai-scan/ai-scan-app-logo.webp"
            loading="eager"
            width="460"
            height="460"
            alt="AI Scan app logo"
            class="ai-scan-logo"
          />
        </div>
      </div>
    </div>
  </div>

  {/* How It Works */}
  <div class="section product-section">
    <div class="container-default w-container">
      <div class="product-heading-content-wrapper">
        <div class="product-heading-wrapper">
          <h2 class="product-heading"><span class="heading-gradient">How It Works</span></h2>
          <div class="product-subheading">Extracting data from printed documents is just that easy with AI Scan!</div>
        </div>
        <div class="product-content-wrapper">
          <div class="_2-block-grid gap-32">
            <div class="plain-svg-card px-32 py-32">
              <div class="card-svg-block">
                <img src="/images/pages/solutions_retails_api_data.svg" loading="lazy" width="80" height="80" alt="" class="card-svg small" />
              </div>
              <div class="svg-card-content-wrapper">
                <h6 class="svg-card-title">Point Your Camera</h6>
                <div class="svg-card-description">Point your camera at any document</div>
              </div>
            </div>
            <div class="plain-svg-card px-32 py-32">
              <div class="card-svg-block">
                <img src="/images/pages/products_scanmobileSDK_img-checker-icon.svg" loading="lazy" width="128" height="128" alt="" class="card-svg small" />
              </div>
              <div class="svg-card-content-wrapper">
                <h6 class="svg-card-title">Take a Picture</h6>
                <div class="svg-card-description">Take a picture of the document</div>
              </div>
            </div>
            <div class="plain-svg-card px-32 py-32">
              <div class="card-svg-block">
                <img src="/images/pages/solutions-hr-whatis-textlocalization.svg" loading="lazy" width="80" height="80" alt="" class="card-svg small" />
              </div>
              <div class="svg-card-content-wrapper">
                <h6 class="svg-card-title">Extract Data</h6>
                <div class="svg-card-description">Copy or share the extracted data instantly</div>
              </div>
            </div>
            <div class="plain-svg-card px-32 py-32">
              <div class="card-svg-block">
                <img src="/images/pages/logistics_landing_why-management.svg" loading="lazy" width="80" height="80" alt="" class="card-svg small" />
              </div>
              <div class="svg-card-content-wrapper">
                <h6 class="svg-card-title">Use Anywhere</h6>
                <div class="svg-card-description">Use the information however you want – it&#x27;s that simple!</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  {/* Supported Documents + Powered By */}
  <div class="section product-section bg-f7f8fc">
    <div class="container-default w-container">
      <div class="product-heading-content-wrapper">
        <div class="product-heading-wrapper">
          <h2 class="product-heading">Supported Documents</h2>
        </div>
        <div class="product-content-wrapper">
          <div class="_3-block-grid">
            <div class="plain-svg-card card-bg-white py-32">
              <div class="card-svg-block svg-center">
                <img src="/images/pages/logistics_landing_why-automated.svg" loading="lazy" width="128" height="128" alt="" class="card-svg small" />
              </div>
              <div class="svg-card-content-wrapper">
                <h6 class="svg-card-title text-center">Receipt</h6>
              </div>
            </div>
            <div class="plain-svg-card card-bg-white py-32">
              <div class="card-svg-block svg-center">
                <img src="/images/pages/invoice.svg" loading="lazy" width="80" height="80" alt="" class="card-svg small" />
              </div>
              <div class="svg-card-content-wrapper">
                <h6 class="svg-card-title text-center">Invoice</h6>
              </div>
            </div>
            <div class="plain-svg-card card-bg-white py-32">
              <div class="card-svg-block svg-center">
                <img src="/images/pages/solutions_retails_api_cs.svg" loading="lazy" width="80" height="80" alt="" class="card-svg small" />
              </div>
              <div class="svg-card-content-wrapper">
                <h6 class="svg-card-title text-center">ID Card</h6>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="container-default ai-scan-powered-by-container w-container">
      <div class="home-heading">
        <div class="text-block powered-by-formx-heading">Powered by</div>
        <div class="powered-by-formx-content">
          <img
            src="/images/pages/ai-scan/fx-notionicon.png"
            loading="lazy"
            width="20"
            height="20"
            alt=""
            class="powered-by-formx-logo"
          />
          <div class="powered-by-formx-text">FormX.ai API</div>
        </div>
      </div>
    </div>
  </div>

  {/* Download AI Scan */}
  <div class="section product-section bg-f7f8fc">
    <div class="container-default w-container">
      <div id="download-link" class="footer-download">
        <h2 class="footer-heading download-header">Download AI Scan</h2>
        <div class="downlaod-on-app-store-flex">
          <a href="http://bit.ly/3ZbBIHW" target="_blank" rel="noopener" class="w-inline-block">
            <img
              src="/images/pages/ai-scan/google-play-badge.png"
              loading="lazy"
              alt="Get it on Google Play"
              class="download-on-app-store-badge"
            />
          </a>
          <a href="https://apps.apple.com/us/app/ai-scan-formx/id6444301909" target="_blank" rel="noopener" class="w-inline-block">
            <img
              src="/images/pages/ai-scan/app-store-badge.svg"
              loading="lazy"
              alt="Download on the App Store"
              class="download-on-app-store-badge"
            />
          </a>
        </div>
      </div>
    </div>
  </div>

</PageLayout>
