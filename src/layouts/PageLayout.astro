---
import BaseLayout from './BaseLayout.astro';
import Header from '@/components/header/Header.astro';
import FooterForm from '@/components/footer/FooterForm.astro';
import Footer from '@/components/footer/Footer.astro';

interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  twitterCard?: string;
  canonicalUrl?: string;
  noIndex?: boolean;
  bodyClass?: string;
  showFooterForm?: boolean;
}

const { showFooterForm = false, ...baseProps } = Astro.props;
---

<BaseLayout {...baseProps}>
  <slot name="head" slot="head" />
  <div
    class="page-wrapper relative min-h-0 min-w-0 max-w-full overflow-hidden max-[479px]:overflow-visible"
  >
    <Header />
    <main id="main-content">
      <slot />
    </main>
  </div>
  {showFooterForm ? <FooterForm /> : <Footer />}
</BaseLayout>
